# ─── OpenRouter ───────────────────────────────────────────────────────────────
# 1. ไปที่ https://openrouter.ai/keys แล้ว copy API key มาใส่ด้านล่าง
# 2. copy ไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env
# 3. ห้าม commit ไฟล์ .env เด็ดขาด (มีใน .gitignore แล้ว)

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model ที่ใช้ — เปลี่ยนได้โดยไม่ต้องแก้ code
# ดูรายชื่อ model ทั้งหมดได้ที่ https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Workspace directory for MCP file tools
# ใส่ absolute path หรือ relative path ก็ได้ (relative นับจาก app.py)
WORKSPACE_PATH=./workspace

# Allowed workspace roots — comma-separated absolute paths
# User can only pick/create workspaces under these directories (runtime safety)
# ถ้าไม่กำหนด จะใช้ project root เป็น default (เหมือนเดิม)
# ตัวอย่าง: ALLOWED_WORKSPACE_ROOTS=/home/user/ai-poc,/mnt/shared
ALLOWED_WORKSPACE_ROOTS=
