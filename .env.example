# ─── OpenRouter ───────────────────────────────────────────────────────────────
# 1. ไปที่ https://openrouter.ai/keys แล้ว copy API key มาใส่ด้านล่าง
# 2. copy ไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env
# 3. ห้าม commit ไฟล์ .env เด็ดขาด (มีใน .gitignore แล้ว)

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model ที่ใช้ — เปลี่ยนได้โดยไม่ต้องแก้ code
# ดูรายชื่อ model ทั้งหมดได้ที่ https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# OpenRouter API request timeout in seconds (default: 60)
# เพิ่มถ้าใช้ model ที่ช้า หรือสร้างเอกสารยาวมาก
OPENROUTER_TIMEOUT=60

# ─── Workspace ────────────────────────────────────────────────────────────────
# Workspace directory for MCP file tools
# ใส่ absolute path หรือ relative path ก็ได้ (relative นับจาก app.py)
WORKSPACE_PATH=./workspace

# Allowed workspace roots — comma-separated absolute paths
# User can only pick/create workspaces under these directories (runtime safety)
# ถ้าไม่กำหนด จะใช้ project root เป็น default
# ตัวอย่าง: ALLOWED_WORKSPACE_ROOTS=/home/user/ai-poc,/mnt/shared
ALLOWED_WORKSPACE_ROOTS=

# Max size of pending_doc sent back from frontend (bytes, default: 204800 = 200KB)
MAX_PENDING_DOC_BYTES=204800

# Web search timeout in seconds (default: 15)
WEB_SEARCH_TIMEOUT=15

# ─── Server (gunicorn) ────────────────────────────────────────────────────────
# จำนวน worker processes (default: 2 — เหมาะกับ 2-4 core)
GUNICORN_WORKERS=2

# Max concurrent SSE connections per worker (default: 50)
GUNICORN_CONNECTIONS=50

# Worker timeout in seconds — ต้องมากกว่า OPENROUTER_TIMEOUT (default: 120)
GUNICORN_TIMEOUT=120

# Log level: debug | info | warning | error (default: info)
GUNICORN_LOG_LEVEL=info

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# จำกัดจำนวน request ต่อ IP บน /api/chat (flask-limiter syntax)
# ตัวอย่าง: "10 per minute", "5 per second", "100 per hour"
CHAT_RATE_LIMIT=10 per minute

# Storage backend สำหรับ rate limit counter (default: memory — ใช้ได้กับ single process)
# Production multi-process: ใช้ Redis → RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# ─── Flask ────────────────────────────────────────────────────────────────────
# เปิด debug mode (อย่าเปิดใน production)
FLASK_DEBUG=0

# Host และ port (default: 0.0.0.0:5000)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
