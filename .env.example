# ─── Setup / การเริ่มต้น ─────────────────────────────────────────────────────
# 1. Copy file นี้เป็น .env
# 2. ใส่ API key จริง
# 3. ห้าม commit ไฟล์ .env
#
# English:
# - Copy this file to .env
# - Fill in the required values
# - Never commit .env

# ─── OpenRouter / Required / จำเป็น ──────────────────────────────────────────
# Get your key from: https://openrouter.ai/keys
# ค่านี้จำเป็น ถ้าไม่มี server จะเรียก AI ไม่ได้

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional / ค่าแนะนำเริ่มต้น
# Change this only if you want another model.
# เปลี่ยนค่าเฉพาะเมื่ออยากใช้ model อื่น
# Model list: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional timeout in seconds.
# เพิ่มค่านี้ถ้า model ช้า หรือสร้างเอกสารยาวมาก
OPENROUTER_TIMEOUT=60

# ─── Output Token Limits / จำนวน token สูงสุดต่อคำตอบ ────────────────────────
# ตั้งตาม model ที่ใช้:
#   Gemini 1.5 Pro/Flash, 2.0 Flash → max 8,192
#   Gemini 2.5 Pro/Flash            → max 65,536
#   Qwen2.5-72B                     → max 32,768
#   Claude Sonnet 4.5               → max 64,000
#
# AGENT_MAX_TOKENS   — document generation (HR, Accounting, Document, PM)
# CHAT_MAX_TOKENS    — chat / advisory / quick answers
# ORCHESTRATOR_MAX_TOKENS — routing JSON only, keep this low
AGENT_MAX_TOKENS=32000
CHAT_MAX_TOKENS=8000
ORCHESTRATOR_MAX_TOKENS=1024

# ─── Workspace / ไฟล์งาน ─────────────────────────────────────────────────────
# Main folder used for saved files.
# ใช้ได้ทั้ง absolute path และ relative path
# Example: ./workspace
WORKSPACE_PATH=./workspace

# Optional security limit.
# จำกัดว่า runtime จะเลือก workspace ได้เฉพาะใต้ path เหล่านี้
# Leave blank to use the project root as the default allowed root.
# Example: ALLOWED_WORKSPACE_ROOTS=/home/user/ai-poc,/mnt/shared
ALLOWED_WORKSPACE_ROOTS=

# Optional. Max size of pending document returned from frontend (bytes).
MAX_PENDING_DOC_BYTES=204800

# Optional. Web search timeout in seconds.
WEB_SEARCH_TIMEOUT=15

# ─── Server / Gunicorn ────────────────────────────────────────────────────────
# Why 4 workers: 1 worker is permanently held by /api/files/stream (SSE),
# leaving only 1 free if you use 2. With 4: SSE + PDF preview + chat all get
# their own worker without queuing. Formula: (2 × CPU cores) + 1, min 4.
GUNICORN_WORKERS=4

# Optional. Max concurrent SSE connections per worker.
GUNICORN_CONNECTIONS=50

# Important: should be higher than OPENROUTER_TIMEOUT.
# สำคัญ: ค่านี้ควรมากกว่า OPENROUTER_TIMEOUT
GUNICORN_TIMEOUT=120

# Log level: debug | info | warning | error
GUNICORN_LOG_LEVEL=info

# ─── Rate Limiting / จำกัด request ────────────────────────────────────────────
# Per-IP limit for /api/chat (flask-limiter syntax)
# Example: "10 per minute", "5 per second", "100 per hour"
CHAT_RATE_LIMIT=10 per minute

# memory:// is fine for local use.
# For production multi-process setups, prefer Redis.
# Example: RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# ─── Flask / App server ───────────────────────────────────────────────────────
# Debug mode. Keep this off in production.
FLASK_DEBUG=0

# Server host and port.
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
